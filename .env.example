# ── Database ────────────────────────────────────────────────────────────────
# Local:    postgresql://capartefegas:yourpassword@localhost:5432/capartefegas
# Neon:     postgresql://user:pass@ep-xxx.neon.tech/capartefegas?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://capartefegas:yourpassword@localhost:5432/capartefegas

# ── Session auth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace_with_a_long_random_string

# ── Cloudinary (product image uploads) ───────────────────────────────────────
# From https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OPay payment gateway ──────────────────────────────────────────────────────
# From https://merchants.opayweb.com → API Keys
# Sandbox base URL: https://sandboxapi.opaycheckout.com
# Live base URL:    https://api.opaycheckout.com
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=
OPAY_PRIVATE_KEY=
OPAY_BASE_URL=https://sandboxapi.opaycheckout.com

# ── App URL (used to build OPay return/callback URLs) ────────────────────────
# Local:      http://localhost:3000
# Production: https://yourdomain.com  (must be HTTPS for OPay live mode)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── WhatsApp business number (country code, no + or spaces) ──────────────────
WHATSAPP_NUMBER=2348000000000

# ── Admin account created by npm run db:seed ─────────────────────────────────
SEED_ADMIN_EMAIL=admin@capartefegas.com
SEED_ADMIN_PASSWORD=ChangeMe123!
