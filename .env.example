# --- Database (Postgres connection string) ---
# Local example:    postgresql://capartefegas:yourpassword@localhost:5432/capartefegas
# Neon example:     postgresql://user:pass@ep-xxxx.neon.tech/capartefegas?sslmode=require
# Supabase example: postgresql://postgres:pass@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://capartefegas:capartefegas_dev@localhost:5432/capartefegas

# --- Session auth ---
# Any long random string. Generate one with: openssl rand -base64 32
SESSION_SECRET=replace_this_with_a_long_random_string

# --- Cloudinary (image storage) ---
# From your Cloudinary dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- WhatsApp business number used at checkout (with country code, no + or spaces) ---
WHATSAPP_NUMBER=2348000000000

# --- Initial admin account, created by the seed script ---
SEED_ADMIN_EMAIL=admin@capartefegas.com
SEED_ADMIN_PASSWORD=ChangeMe123!
